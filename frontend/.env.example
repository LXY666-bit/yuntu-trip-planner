# Frontend environment variables
# Copy this file to frontend/.env and fill in the values marked CHANGE_ME.

# Optional in dev: Vite already proxies /api to the backend.
# Set this only when the frontend is served separately without the Vite proxy.
VITE_API_BASE_URL=

# Required for map rendering in DiscoveryMap / result map tabs.
# This is the AMap Web JS API key, which may be different from the backend Web Service key.
VITE_AMAP_WEB_JS_KEY=CHANGE_ME
