# Backend environment variables
# Copy this file to backend/.env and fill in the values marked CHANGE_ME.

# LLM API configuration (OpenAI-compatible)
LLM_API_KEY=CHANGE_ME
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_ID=gpt-4o

# AMap Web Service API Key
AMAP_API_KEY=CHANGE_ME

# AIGoHotel MCP endpoint (via ModelScope)
# AIGOHOTEL_MCP_URL=https://mcp.api-inference.modelscope.net/xxx/mcp

# Bing Search MCP endpoint (via ModelScope)
# BING_MCP_URL=https://mcp.api-inference.modelscope.net/xxx/sse

# Xiaohongshu (RED) Cookie for travelogue search (optional)
# XHS_COOKIE=CHANGE_ME

# Database (default SQLite)
DATABASE_URL=sqlite+aiosqlite:///data/trips.db

# Application
APP_NAME=YUNTU AI Trip Planner
APP_VERSION=1.0.0
LOG_LEVEL=INFO
